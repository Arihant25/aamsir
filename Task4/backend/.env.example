# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL of the running Ollama instance.
AAMSIR_OLLAMA_URL=http://localhost:11434

# Ollama model used for answer generation and agentic query rewriting.
AAMSIR_OLLAMA_MODEL=qwen2.5:7b

# ── Embedding ─────────────────────────────────────────────────────────────────
# Sentence-Transformers model name (downloaded automatically on first run).
AAMSIR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
AAMSIR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
